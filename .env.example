# ================================
# ROOT ENV (copy sang .env)
# ================================

# === DATABASE ===
DATABASE_URL="postgresql://auction_user:auction_pass@localhost:5432/auction_db"
POSTGRES_USER=auction_user
POSTGRES_PASSWORD=auction_pass
POSTGRES_DB=auction_db

# === REDIS ===
REDIS_URL="redis://localhost:6379"

# === JWT ===
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === SERVER ===
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:5173
CLUSTER_WORKERS=1
SCHEDULER_ENABLED=true
SCHEDULER_BATCH_LIMIT=50
SOCKET_TRANSPORTS=websocket
SOCKET_PER_MESSAGE_DEFLATE=false
SOCKET_REDIS_ADAPTER_ENABLED=false
DB_QUERY_LOG_ENABLED=false

# === FRONTEND ===
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001
